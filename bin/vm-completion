_vm()
{
    local cur prev opts vm_list
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    opts="console create info ls ping reboot restore rm save set ssh \
        start stop storage networks templates top --version --help"

    if [[ COMP_CWORD -gt 1 ]]; then
        case "${COMP_WORDS[1]}" in
            --version | --help)
                return 0
            ;;
            top)
                return 0
            ;;
            create)
                if [[ "$prev" == "--template" ]]; then
                    templates="$(vm templates --short)"
                    COMPREPLY=( $(compgen -W "${templates}" -- ${cur}) )
                elif [[ "$prev" == "--network" ]]; then
                    templates="$(vm networks --short)"
                    COMPREPLY=( $(compgen -W "${templates}" -- ${cur}) )
                elif [[ "$prev" == "--storage" ]]; then
                    templates="$(vm storage --short)"
                    COMPREPLY=( $(compgen -W "${templates}" -- ${cur}) )
                elif [[ "$prev" == "--vcpu" ]] || [[ "$prev" == "--ip" ]] || \
                        [[ "$prev" == "--memory" ]] || [[ "$prev" == "--size" ]]; then
                    return 0
                else
                    create_opts="--vcpu --ip --memory --storage --template --network --size"
                    COMPREPLY=( $(compgen -W "${create_opts}" -- ${cur}) )
                fi
                return 0
            ;;
            list | ls)
                COMPREPLY=( $(compgen -W "--active --inactive --short --backup" -- ${cur}) )
                return 0
            ;;
            templates | storage | networks)
                COMPREPLY=( $(compgen -W "--short" -- ${cur}) )
                return 0
            ;;
            remove | rm)
                vm_list="$(vm list --inactive --short)"
                COMPREPLY=( $(compgen -W "--yes ${vm_list}" -- ${cur}) )
                return 0
            ;;
            set | info)
                if [[ COMP_CWORD -eq 2 ]]; then
                    vm_list="$(vm list --short)"
                    COMPREPLY=( $(compgen -W "${vm_list}" -- ${cur}) )
                elif [[ "${COMP_WORDS[1]}" == "set" ]]; then
                    opts="--ip --backup --starting --os-type --os-name --os-version"
                    if [[ "$prev" == "--backup" ]]; then
                        COMPREPLY=( $(compgen -W "on off" -- ${cur}) )
                        return 0
                    elif [[ "$prev" == "--starting" ]]; then
                        COMPREPLY=( $(compgen -W "auto manual" -- ${cur}) )
                        return 0
                    elif [[ "$prev" == "--*" ]]; then
                        return 0
                    fi
                    COMPREPLY=( $(compgen -W "${opts}" -- ${cur}) )
                fi
                return 0
            ;;
            ping | reboot | ssh | console)
                if [[ COMP_CWORD -eq 2 ]]; then
                    vm_list="$(vm list --active --short)"
                    COMPREPLY=( $(compgen -W "${vm_list}" -- ${cur}) )
                fi
                return 0
            ;;
            stop | save)
                vm_list="$(vm list --active --short)"
                COMPREPLY=( $(compgen -W "${vm_list}" -- ${cur}) )
                return 0
            ;;
            start | restore)
                vm_list="$(vm list --inactive --short)"
                COMPREPLY=( $(compgen -W "${vm_list}" -- ${cur}) )
                return 0
            ;;
            *)
            ;;
        esac
    fi

    if [[ COMP_CWORD -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "${opts}" -- ${cur}) )
        return 0
    fi

    return 0
}

complete -F _vm vm
